# Doit correspondre au DOMAIN de l'edge Traefik.
DOMAIN=localhost

# Xdebug : off par défaut (prod-safe, aucun overhead).
# Pour débugger en dev, décommenter :
# XDEBUG_MODE=develop,debug

# MySQL (accès interne au réseau `internal`, hôte : mysql).
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=sandbox
MYSQL_USER=sandbox
MYSQL_PASSWORD=sandbox
