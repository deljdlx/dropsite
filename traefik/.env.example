# Domaine racine des sites.
#  - dev  : localhost  (*.localhost résout vers 127.0.0.1 sans configuration DNS)
#  - prod : ton vrai domaine, ex. example.com  (avec un DNS wildcard *.example.com)
DOMAIN=localhost

# Email de contact pour Let's Encrypt (prod).
ACME_EMAIL=admin@example.com

# Provider DNS pour le challenge ACME DNS-01 (prod, certificat wildcard).
# Laisser VIDE en dev. En prod : cloudflare | ovh | gandiv5 | ... (voir doc Traefik)
# et fournir les credentials du provider (variables d'environnement dédiées).
ACME_DNS_PROVIDER=
