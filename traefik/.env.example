# Domaine racine des sites.
#  - dev  : localhost  (*.localhost résout vers 127.0.0.1 sans configuration DNS)
#  - prod : ton vrai domaine, ex. example.com  (avec un DNS wildcard *.example.com)
DOMAIN=localhost

# Email de contact pour Let's Encrypt (prod).
ACME_EMAIL=admin@example.com

# Provider DNS pour le challenge ACME DNS-01 (prod, certificat wildcard).
# Laisser VIDE en dev. En prod : cloudflare | ovh | gandiv5 | ... (voir doc Traefik)
ACME_DNS_PROVIDER=gandiv5

# Autorité ACME. Staging pour tester sans consommer les quotas Let's Encrypt,
# puis production une fois le cert obtenu :
#   staging : https://acme-staging-v02.api.letsencrypt.org/directory
#   prod    : https://acme-v02.api.letsencrypt.org/directory
ACME_CA_SERVER=https://acme-staging-v02.api.letsencrypt.org/directory

# Credentials du provider DNS (SECRET — ne jamais commiter).
# Gandi : Personal Access Token avec droit de gestion DNS de la zone.
GANDIV5_PERSONAL_ACCESS_TOKEN=
