# Domaine racine des sites.
#  - dev  : localhost  (*.localhost résout vers 127.0.0.1 sans configuration DNS)
#  - prod : ton vrai domaine, ex. example.com  (avec un DNS wildcard *.example.com)
DOMAIN=localhost

# --- PROD uniquement (ACME DNS-01 wildcard) ---
# Le resolver ACME (email, provider gandiv5, caServer staging/prod) est configuré
# dans traefik.yml. Ici, seul le SECRET est requis, et il est activé via
# docker-compose.prod.yml. Laisser vide en dev.
#
# Gandi : Personal Access Token avec droit de gestion DNS de la zone (SECRET —
# ne jamais commiter).
GANDIV5_PERSONAL_ACCESS_TOKEN=
